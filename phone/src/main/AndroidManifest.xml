<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network sensors only — no privileged perms. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Location — runtime permission required; prompted via LocationHero. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Cellular — READ_BASIC_PHONE_STATE is a NORMAL permission (no runtime prompt, API 33+).
         Grants dataNetworkType + signalStrength. Degrades gracefully on API < 33. -->
    <uses-permission android:name="android.permission.READ_BASIC_PHONE_STATE" />

    <!-- Foreground service — normal permission (no runtime dialog). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- API 34+ type declaration for the live-stats notification service. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- API 33+ — show notifications; user must grant in app settings if not auto-approved. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Normal permission — auto-restart live-stats service after device reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <queries>
        <package android:name="com.google.android.wearable.app" />
    </queries>

    <application
        android:name=".MarrowApp"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Marrow"
        tools:targetApi="34">

        <!-- Required so the Wearable API can bind. -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Marrow">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Listens for /marrow/* messages from the watch. -->
        <service
            android:name=".sync.MarrowWearListener"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/marrow" />
            </intent-filter>
        </service>

        <!-- Quick Settings tile — shows battery % + RAM % in the notification shade. -->
        <service
            android:name=".tile.MarrowTileService"
            android:exported="true"
            android:icon="@drawable/ic_launcher_foreground"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Ambient live-stats foreground service (optional, user opt-in). -->
        <!-- Start: send ACTION_START Intent; Stop: send ACTION_STOP Intent. -->
        <service
            android:name=".notification.MarrowNotificationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Home-screen widget (Jetpack Glance). -->
        <receiver
            android:name=".widget.MarrowWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/marrow_widget_info" />
        </receiver>

        <!-- Restores the live-stats notification service on reboot if the user had it enabled. -->
        <receiver
            android:name=".notification.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
